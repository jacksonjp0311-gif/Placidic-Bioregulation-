  ],
  "automatic_kernel_replacement_allowed": false,
  "kernel_mutation_allowed": false,
  "evidence_packaging_is_biological_validation": false,
  "evidence_packaging_is_medical_safety": false,
  "non_claim_locks": [
    "not_medical",
    "not_biological_law",
    "not_mechanism_proof"
  ]
}
