{
  "version": "PBSA-EvidencePackagePolicy-v2.5",
  "policy_id": "evidence_package_policy_v2_5",
  "description": "PBSA v2.5 evidence package hardening policy.",
  "required_verifiers": [
    "hash_manifest",
    "report_chain",
    "ledger_continuity",
    "rcc_anchor_verification",
    "downgrade_lock_verification",
    "failure_surface_verification"
