{
  "version": "PBSA-EvolutionPolicy-v2.3",
  "mode": "diagnostic_first",
  "kernel_mutation_allowed": false,
  "acceptance_rules": {
    "tests_must_pass": true,
    "pba_e_count_must_be_zero": true,
    "baseline_comparison_required": true,
    "non_claim_locks_required": true,
    "holdout_required_before_kernel_replacement": true,
    "do_not_hide_baseline_wins": true,
    "evolution_report_required": true,
    "decision_ledger_required": true,
    "holdout_summary_required": true,
    "candidate_readiness_report_required": true,
    "candidate_execution_disabled_in_v1_3": true,
    "champion_challenger_report_required": true,
    "original_suite_comparison_required": true,
    "holdout_suite_comparison_required": true,
    "baseline_visibility_required": true,
    "automatic_replacement_forbidden": true,
    "route_policy_required": true,
    "route_evidence_required": true,
    "routed_suite_report_required": true,
    "routed_validation_report_required": true,
    "route_advantage_required": true,
    "route_preservation_score_required": true,
    "route_failure_surface_required": true,
    "external_domain_configs_required": true,
    "external_validation_report_required": true,
    "advantage_drift_required": true,
    "preservation_drift_required": true,
    "external_failure_surface_required": true,
    "stress_domain_configs_required": true,
    "stress_validation_report_required": true,
    "safe_fail_score_required": true,
    "crash_rate_required": true,
    "stress_failure_surface_required": true
  },
  "score_policy": {
    "primary_metric": "cumulative_deviation",
    "lower_is_better": true,
    "preserve_or_explain_pba_a_loss": true
  },
  "memory_promotion": {
    "allow": [
      "reproducible_improvement",
      "regime_detection_rule",
      "baseline_superiority_lesson",
      "implementation_constraint",
      "failure_lesson",
      "rcc_context_constraint"
    ],
    "reject": [
      "medical_claim",
      "biological_law_claim",
      "mechanism_proof_claim",
      "single_run_hype",
      "readme_polish_as_evidence"
    ]
  },
  "diagnostic_schema": "multi_label_regime_detection",
  "rcc_sync_required": true,
  "holdout_required_before_candidate_execution": true,
  "candidate_execution_allowed": true,
  "candidate_promotion_allowed": false,
  "candidate_execution_scope": "comparison_harness_only",
  "automatic_kernel_replacement_allowed": false,
  "promotion_requires_manual_review": true,
  "architecture_mode": "stress_adversarial_validation",
  "global_decision": "route_by_regime",
  "routing_is_global_replacement": false,
  "validation_decision_required": true,
  "routed_validation_is_biological_validation": false,
  "external_validation_required": true,
  "route_drift_required": true,
  "external_failure_surface_required": true,
  "external_validation_is_biological_validation": false,
  "stress_validation_required": true,
  "safe_fail_required": true,
  "crash_rate_required": true,
  "malformed_input_guard_required": true,
  "contradictory_regime_detector_required": true,
  "stress_validation_is_biological_validation": false,
  "stress_validation_is_medical_safety": false
}